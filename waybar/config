{
    "layer": "top",
    "position": "top",
    "height": 30,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 8,
    "margin-right": 8,
    "spacing": 0,
    "modules-left": [
        "custom/xaccefy",
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/updates",
        "custom/vpn",
        "network",
        "pulseaudio",
        "cpu",
        "memory",
        "battery",
        "hyprland/language",
        "tray"
    ],

    "custom/xaccefy": {
        "format": "[xcf]",
        "tooltip": false,
        "on-click": "rofi -show drun -replace -i -theme ~/.config/rofi/launchers/type-1/glass-compact.rasi"
    },
    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{name}",
        "sort-by-number": true,
        "show-empty": false,
        "all-outputs": true,
        "persistent-workspaces": {
            "*": ["1", "2", "3", "4"]
        },
        "disable-scroll": true
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 36,
        "separate-outputs": true,
        "rewrite": {
            "(.*) - Zen Browser": "$1",
            "(.*) - Mozilla Firefox": "$1",
            "(.*) - Visual Studio Code": "$1",
            "^[^ ]+@[^:]+: .*/([^/]+)$": "$1",
            "^[^ ]+@[^:]+: (.*)$": "$1"
        }
    },
    "custom/updates": {
        "format": "upd {}",
        "exec": "$HOME/.config/waybar/scripts/updates.sh",
        "exec-if": "ping -c1 -W2 archlinux.org >/dev/null 2>&1",
        "return-type": "json",
        "interval": 3600,
        "signal": 8,
        "tooltip": true,
        "on-click": "$HOME/.config/waybar/scripts/update-click.sh"
    },
    "custom/vpn": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/vpn.sh",
        "return-type": "json",
        "interval": 30,
        "tooltip": true,
        "on-click": "$HOME/.config/waybar/scripts/vpn.sh copy"
    },
    "network": {
        "format": "{ifname}",
        "format-wifi": " {essid} [{signalStrength}%]",
        "format-ethernet": " {ifname}",
        "format-disconnected": " offline",
        "tooltip-format-wifi": "iface: {ifname}\nssid: {essid}\nsignal: {signalStrength}%\nip: {ipaddr}/{cidr}\nfreq: {frequency}GHz",
        "tooltip-format-ethernet": "iface: {ifname}\nip: {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "no connection",
        "interval": 15,
        "on-click": "sh -c 'pkill -x nm-connection-editor 2>/dev/null; nm-connection-editor'"
    },
    "cpu": {
        "format": "cpu {usage}%",
        "format-alt": "cpu {load}",
        "interval": 5,
        "states": {
            "warning": 70,
            "critical": 90
        },
        "on-click-right": "ghostty -e btop",
        "tooltip-format": "cpu: {usage}%\nfreq: {avg_frequency}GHz\nload: {load}"
    },
    "memory": {
        "format": "mem {percentage}%",
        "format-alt": "mem {used:0.1f}G",
        "interval": 10,
        "states": {
            "warning": 75,
            "critical": 90
        },
        "on-click-right": "ghostty -e btop",
        "tooltip-format": "ram: {used:0.1f}/{total:0.1f}GiB\nswap: {swapUsed:0.1f}/{swapTotal:0.1f}GiB"
    },
    "battery": {
        "format": "bat {capacity}%",
        "format-charging": "bat {capacity}% ↑",
        "format-plugged": "bat {capacity}% ⚡",
        "format-alt": "bat {time}",
        "states": {
            "good": 90,
            "warning": 30,
            "critical": 20
        },
        "tooltip-format": "battery: {capacity}%\n{timeTo}\npower: {power:.1f}W"
    },
    "hyprland/language": {
        "keyboard-name": "at-translated-set-2-keyboard",
        "format": "{}",
        "format-en": "en",
        "format-mn": "mn",
        "tooltip-format": "keyboard: {long}"
    },
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M}",
        "interval": 60,
        "tooltip-format": "<tt>{calendar}</tt>"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 3,
        "show-passive-items": false
    },
    "pulseaudio": {
        "format": "vol {volume}%",
        "format-muted": "vol mute",
        "format-icons": {
            "default": [
                "",
                ""
            ]
        },
        "max-volume": 100,
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
    }
}
