configuration {
    modi: "drun";
    show-icons: true;
    matching: "normal";
    drun-match-fields: "name,generic,exec,categories,keywords";
    drun-display-format: "{name}";
    display-drun: "apps";
    icon-theme: "Papirus";
}

* {
    bg: rgba(18, 18, 18, 0.95);
    panel: rgba(255, 255, 255, 0.10);
    panel-hover: rgba(255, 255, 255, 0.18);
    border: rgba(255, 255, 255, 0.16);
    text: #f2f4f8;
    muted: #919aa7;
    accent: #82aaff;
    urgent: #ee5396;

    font: "JetBrainsMono Nerd Font Mono 12";
    background-color: transparent;
    text-color: @text;
    margin: 0;
    padding: 0;
    spacing: 0;
}

window {
    transparency: "real";
    location: center;
    anchor: center;
    width: 500px;
    y-offset: -20px;
    border: 1px;
    border-color: @border;
    border-radius: 5px;
    background-color: @bg;
}

mainbox {
    children: [ "inputbar", "listview" ];
    padding: 12px;
    spacing: 10px;
    background-color: transparent;
}

inputbar {
    children: [ "entry" ];
    padding: 8px 10px;
    spacing: 8px;
    border: 1px;
    border-color: @border;
    border-radius: 5px;
    background-color: @panel;
}

entry {
    placeholder: "search";
    placeholder-color: @muted;
    text-color: @text;
    horizontal-align: 0.5;
    background-color: transparent;
}

listview {
    columns: 1;
    lines: 6;
    dynamic: true;
    fixed-height: false;
    scrollbar: false;
    spacing: 4px;
    background-color: transparent;
}

element {
    padding: 8px 10px;
    spacing: 8px;
    border: 1px;
    border-color: transparent;
    border-radius: 5px;
    background-color: transparent;
}

element normal.normal {
    text-color: @text;
}

element normal.urgent {
    text-color: @urgent;
}

element selected.normal,
element selected.active {
    background-color: @panel-hover;
    border-color: @border;
    text-color: @text;
}

element-icon {
    size: 20px;
    background-color: transparent;
}

element-text {
    vertical-align: 0.5;
    background-color: transparent;
    text-color: inherit;
}
